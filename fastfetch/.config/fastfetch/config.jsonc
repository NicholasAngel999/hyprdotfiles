{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

"logo": {
  "type": "file",
  "source": "~/.config/fastfetch/clone.txt",
  "color": {
    "1": "#c45c1a",
    "2": "#d4621e"
  }
},

"display": {
  "separator": "  ",
  "color": {
    "keys": "#c45c1a",
    "title": "#d4621e",
    "output": "#e8e0d0"
  }
},

"modules": [
  "title",
  "separator",
  "os",
  "kernel",
  "uptime",
  "packages",
  "wm",
  "cpu",
  "gpu",
  "memory",
  "battery"
]
}
