{
  "layer": "top",
  "position": "top",
  "height": 30,
  "margin": 6,
  "modules-left": [
    "workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "battery",
    "network",
    "bluetooth", 
    "brightnessctl"
  ],
  "workspaces": {
    "format": "{icon} {name}",
    "icon": {
      "1": "󰈹",
      "2": "",
      "3": "",
      "4": "",
      "5": ""
    },
    "on-click": "hyprctl dispatch workspace {workspace}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },
  "clock": {
    "format": " %a %d %b %H:%M"
  },
  "pulseaudio": {
    "format": " {volume}%"
  },
  "battery": {
    "format": "{capacity}% "
  },
  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "",
    "format-disconnected": "󰖪"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 8
  }
}
